# Codex execpolicy command rules for this repository.

# forbid
prefix_rule(pattern=["bundle", "open"], decision="forbidden")
prefix_rule(pattern=["git", "push", "origin", "main"], decision="forbidden")
prefix_rule(pattern=["git", "push", "origin", "HEAD:main"], decision="forbidden")
prefix_rule(pattern=["git", "push", "--force", "origin", "main"], decision="forbidden")
prefix_rule(pattern=["git", "push", "--force-with-lease", "origin", "main"], decision="forbidden")
prefix_rule(pattern=["git", "push", "-f", "origin", "main"], decision="forbidden")
prefix_rule(pattern=["git", "push", "-u", "origin", "main"], decision="forbidden")
prefix_rule(pattern=["git", "push", "--set-upstream", "origin", "main"], decision="forbidden")
prefix_rule(pattern=["git", "push", "--force"], decision="forbidden")
prefix_rule(pattern=["git", "push", "-f"], decision="forbidden")
# keep gh api read-oriented by default
prefix_rule(pattern=["gh", "api", "--method", "POST"], decision="forbidden")
prefix_rule(pattern=["gh", "api", "--method", "PUT"], decision="forbidden")
prefix_rule(pattern=["gh", "api", "--method", "PATCH"], decision="forbidden")
prefix_rule(pattern=["gh", "api", "--method", "DELETE"], decision="forbidden")
prefix_rule(pattern=["gh", "api", "-X", "POST"], decision="forbidden")
prefix_rule(pattern=["gh", "api", "-X", "PUT"], decision="forbidden")
prefix_rule(pattern=["gh", "api", "-X", "PATCH"], decision="forbidden")
prefix_rule(pattern=["gh", "api", "-X", "DELETE"], decision="forbidden")

# prompt
prefix_rule(pattern=["bundle", "install"], decision="prompt")
prefix_rule(pattern=["bundle", "update"], decision="prompt")
prefix_rule(pattern=["gh", "pr", "close"], decision="prompt")
prefix_rule(pattern=["gh", "pr", "create"], decision="prompt")
prefix_rule(pattern=["gh", "pr", "edit"], decision="prompt")
prefix_rule(pattern=["gh", "pr", "merge"], decision="prompt")
prefix_rule(pattern=["git", "merge"], decision="prompt")
prefix_rule(pattern=["git", "push"], decision="prompt")
prefix_rule(pattern=["git", "rebase"], decision="prompt")
prefix_rule(pattern=["git", "rm"], decision="prompt")

# allow
prefix_rule(pattern=["bundle", "exec", "jekyll"], decision="allow")
prefix_rule(pattern=["bundle", "info"], decision="allow")
prefix_rule(pattern=["bundle", "list"], decision="allow")
prefix_rule(pattern=["bundle", "show"], decision="allow")
prefix_rule(pattern=["cat"], decision="allow")
prefix_rule(pattern=["diff"], decision="allow")
prefix_rule(pattern=["file"], decision="allow")
prefix_rule(pattern=["find"], decision="allow")
prefix_rule(pattern=["gh", "api"], decision="allow")
prefix_rule(pattern=["gh", "issue", "list"], decision="allow")
prefix_rule(pattern=["gh", "issue", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "checks"], decision="allow")
prefix_rule(pattern=["gh", "pr", "diff"], decision="allow")
prefix_rule(pattern=["gh", "pr", "list"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "repo", "view"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "branch"], decision="allow")
prefix_rule(pattern=["git", "checkout"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "diff"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="allow")
prefix_rule(pattern=["git", "log"], decision="allow")
prefix_rule(pattern=["git", "show"], decision="allow")
prefix_rule(pattern=["git", "status"], decision="allow")
prefix_rule(pattern=["grep"], decision="allow")
prefix_rule(pattern=["head"], decision="allow")
prefix_rule(pattern=["ls"], decision="allow")
prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["stat"], decision="allow")
prefix_rule(pattern=["tail"], decision="allow")
prefix_rule(pattern=["tree"], decision="allow")
prefix_rule(pattern=["wc"], decision="allow")
prefix_rule(pattern=["which"], decision="allow")
